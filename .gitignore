# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# Node
node_modules/
dist/
build/
*.log

# Env / secrets — NEVER commit API keys
.env
.env.*
*.key
secrets.*
config.local.*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Local data / scratch
tmp/
scratch/
*.local

# Eval outputs (may reference the private corpus — never commit)
# Broad rule: every JSON and log under eval/ is a result/selection artifact.
# The eval CODE is .py only; no .py is ignored here.
eval/*.json
eval/*.jsonl
eval/*.log
